{
    "manifest_version": 3,
    "name": "MatugenFox",
    "version": "1.0",
    "description": "Dynamic webpage theming using Matugen colors",
    "browser_specific_settings": {
        "gecko": {
            "id": "matugenfox@ubaid.com"
        }
    },
    "permissions": [
        "nativeMessaging",
        "storage",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "icons": {
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "MatugenFox",
        "default_icon": "icons/icon.png"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ]
}
